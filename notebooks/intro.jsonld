        { "@id": "https://notebook.semantic.consulting/notebook1/#nature-of-relationships" },
        { "@id": "https://notebook.semantic.consulting/notebook1/#transitivity" },
        { "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment" },
        { "@id": "https://notebook.semantic.consulting/notebook1/#querying-the-graph" }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#identity",
      "@type": "sembook:Lab",
      "sembook:label": "Identity and Connection",
      "sembook:cssClass": "grid grid-cols-2 grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#identity-doc-a",
          "@type": "sembook:JsonLdPanel",
          "sembook:label": "Document A",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col",
          "sembook:initialContent": "{\n  \"id\": \"441\",\n  \"title\": \"G\\u00f6del, Escher, Bach\",\n  \"author_id\": \"872\",\n  \"published\": 1979\n}"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#identity-doc-b",
          "@type": "sembook:JsonLdPanel",
          "sembook:label": "Document B",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col",
          "sembook:initialContent": "{\n  \"id\": \"872\",\n  \"name\": \"Douglas Hofstadter\",\n  \"affiliation_id\": \"34\"\n}"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#identity-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "col-span-2 overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#identity-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#identity> } }"
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#data-in-context",
      "@type": "sembook:Lab",
      "sembook:label": "Data and Context",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#data-in-context-editor",
          "@type": "sembook:JsonLdContextPanel",
          "sembook:label": "Book Record",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:initialContent": "{\n  \"@id\": \"https://example.com/Book/Id/8268\",\n  \"title\": \"Elizabeth the Queen: The Life of a Modern Monarch\",\n  \"isbn\": \"0812979796\",\n  \"about\": {\n    \"@id\": \"https://dbpedia.org/resource/Elizabeth_II\",\n    \"name\": \"Elizabeth Windsor\",\n    \"title\": \"Queen of the United Kingdom\"\n  },\n  \"author\": {\n    \"@id\": \"https://example.com/Author/Id/35626\",\n    \"name\": \"Sally Bedell Smith\",\n    \"title\": \"Biographer\"\n  }\n}",
          "sembook:initialContext": "{\n  \"@context\": {\n    \"title\": \"https://example.com/ns#title\",\n    \"about\": {\n      \"@id\": \"https://example.com/ns#about\",\n      \"@context\": {\n        \"title\": \"https://example.com/ns#positionHeld\"\n      }\n    },\n    \"author\": {\n      \"@id\": \"https://example.com/ns#author\"\n    }\n  }\n}"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#data-in-context-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#data-in-context-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#data-in-context> } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#data-in-context-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#introducing-turtle",
      "@type": "sembook:Lab",
      "sembook:label": "Two Syntaxes, One Graph",
      "sembook:cssClass": "grid grid-cols-2 grid-rows-[1fr] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#introducing-turtle-jsonld",
          "@type": "sembook:JsonLdPanel",
          "sembook:label": "JSON-LD",
          "sembook:cssClass": "overflow-hidden flex flex-col border-r border-slate-200",
          "sembook:initialContent": "{\n  \"@context\": {\n    \"@base\": \"https://catalog.example.net/\",\n    \"schema\": \"http://schema.org/\",\n    \"id\": \"@id\"\n  },\n  \"id\": \"/book/979-8868804090\",\n  \"@type\": \"schema:Book\",\n  \"schema:name\": \"Mastering Software Architecture\",\n  \"schema:isbn\": \"979-8868804090\",\n  \"schema:datePublished\": \"2025\",\n  \"schema:author\": {\n    \"id\": \"https://w3id.org/people/michael\",\n    \"schema:name\": \"Michael Carducci\"\n  }\n}"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#introducing-turtle-turtle",
          "@type": "sembook:TurtlePanel",
          "sembook:label": "Turtle",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH <https://notebook.semantic.consulting/notebook1/#introducing-turtle> { ?s ?p ?o } }"
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#asserting-triples",
      "@type": "sembook:Lab",
      "sembook:label": "Defining Terms",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#asserting-triples-writer",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Turtle",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n# ── Our ontology ──────────────────────────────────────\n\nex:title a rdf:Property ;\n    rdfs:label \"Title\" ;\n    rdfs:comment \"The title of a published work\" ;\n    rdfs:range xsd:string .\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#asserting-triples-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#asserting-triples-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#asserting-triples-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#asserting-triples> } }"
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#defining-classes",
      "@type": "sembook:Lab",
      "sembook:label": "Classes and Subclasses",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#defining-classes-writer",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Turtle",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n@prefix schema: <http://schema.org/> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n\n# ── Our ontology ──────────────────────────────────────\n\nex:Book a rdfs:Class ;\n    rdfs:label \"Book\" ;\n    rdfs:comment \"A published written work\" .\n\n# ── Our data ──────────────────────────────────────────\n\n<https://example.com/Book/Id/441> a ex:Book .\n\n# Our world has met more kinds of things than the graph knows about.\n# Declare them, relate them, and claim their members:\n#\n#   ex:Author        — who below counts? What else is an Author?\n#   schema:Person    — every Author is one. Who else — always?\n#   ex:Organization  — Hofstadter has an affiliation… to what kind of thing?\n#\n# (And Elizabeth? What IS she, exactly? …Do we actually know?)\n#\n# The cast so far:\n#   <https://example.com/Author/Id/872>          Douglas Hofstadter\n#   <https://example.com/Author/Id/35626>        Sally Bedell Smith\n#   <https://w3id.org/people/michael>            Michael Carducci\n#   <https://dbpedia.org/resource/Elizabeth_II>  Elizabeth II\n#   <https://example.com/Org/Id/34>              Hofstadter's affiliation\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#defining-classes-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#defining-classes-entities",
              "@type": "sembook:EntityPanel",
              "sembook:label": "Entities",
              "sembook:scope": { "@id": "sembook:CumulativeScope" },
              "sembook:sparql": "SELECT DISTINCT ?class ?parentClass ?instance ?instanceLabel ?classLabel WHERE { GRAPH ?g { VALUES ?g { <https://notebook.semantic.consulting/notebook1/#defining-classes> } { { ?anyInstance a ?class } UNION { ?class a <http://www.w3.org/2000/01/rdf-schema#Class> } UNION { ?class a <http://www.w3.org/2002/07/owl#Class> } UNION { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?anyParent } UNION { ?anySub <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?class } } FILTER(!isBlank(?class)) FILTER(!STRSTARTS(STR(?class), \"https://notebook.semantic.consulting/vocab#\")) OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?parentClass . FILTER(!STRSTARTS(STR(?parentClass), \"https://notebook.semantic.consulting/vocab#\")) } OPTIONAL { ?instance a ?class . FILTER(!isBlank(?instance)) OPTIONAL { ?instance <http://www.w3.org/2000/01/rdf-schema#label> ?instanceLabel } } OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#label> ?classLabel } } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#defining-classes-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#defining-classes-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#defining-classes> } }"
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#merging-vocabularies",
      "@type": "sembook:Lab",
      "sembook:label": "Merging Vocabularies",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#merging-vocabularies-writer",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Turtle",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n@prefix schema: <http://schema.org/> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n\n# ── Our ontology (alignments) ──────────────────────────\n\n# Every title is a name. Not every name is a title.\n# One-way containment — the graph already has a word for that:\n\nex:title rdfs:subPropertyOf schema:name .\n\n# What else did we learn today? Align the rest:\n#\n#   ex:author  and  schema:author   — every one of ours is one of theirs… and?\n#   ex:Book    and  schema:Book     — classes too: rdfs:subClassOf, both ways?\n#   ex:isbn    and  schema:isbn     — careful: is this one-way… or both?\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#merging-vocabularies-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#merging-vocabularies-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#merging-vocabularies-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#merging-vocabularies> } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#merging-vocabularies-full-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Full Graph",
              "sembook:scope": { "@id": "sembook:CumulativeScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#merging-vocabularies> } }"
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#integration-for-free",
      "@type": "sembook:Lab",
      "sembook:label": "Integration for Free",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#integration-for-free-record",
          "@type": "sembook:JsonLdPanel",
          "sembook:label": "DBpedia Record (Fetch it)",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:initialContent": "{}",
          "sembook:fetchUrl": "../datasets/elizabeth-dbpedia.jsonld"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#integration-for-free-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#integration-for-free-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#integration-for-free> } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#integration-for-free-entities",
              "@type": "sembook:EntityPanel",
              "sembook:label": "Entities",
              "sembook:scope": { "@id": "sembook:CumulativeScope" },
              "sembook:sparql": "SELECT DISTINCT ?class ?parentClass ?instance ?instanceLabel ?classLabel WHERE { GRAPH ?g { VALUES ?g { <https://notebook.semantic.consulting/notebook1/#integration-for-free> } { { ?anyInstance a ?class } UNION { ?class a <http://www.w3.org/2000/01/rdf-schema#Class> } UNION { ?class a <http://www.w3.org/2002/07/owl#Class> } UNION { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?anyParent } UNION { ?anySub <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?class } } FILTER(!isBlank(?class)) FILTER(!STRSTARTS(STR(?class), \"https://notebook.semantic.consulting/vocab#\")) OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?parentClass . FILTER(!STRSTARTS(STR(?parentClass), \"https://notebook.semantic.consulting/vocab#\")) } OPTIONAL { ?instance a ?class . FILTER(!isBlank(?instance)) OPTIONAL { ?instance <http://www.w3.org/2000/01/rdf-schema#label> ?instanceLabel } } OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#label> ?classLabel } } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#integration-for-free-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#standing-on-shoulders",
      "@type": "sembook:Lab",
      "sembook:label": "Standing on Shoulders",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#standing-on-shoulders-writer",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "FOAF Record (Fetch it)",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:fetchUrl": "../datasets/michael-foaf.ttl"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#standing-on-shoulders-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#standing-on-shoulders-entities",
              "@type": "sembook:EntityPanel",
              "sembook:label": "Entities",
              "sembook:scope": { "@id": "sembook:CumulativeScope" },
              "sembook:sparql": "SELECT DISTINCT ?class ?parentClass ?instance ?instanceLabel ?classLabel WHERE { GRAPH ?g { VALUES ?g { <https://notebook.semantic.consulting/notebook1/#standing-on-shoulders> } { { ?anyInstance a ?class } UNION { ?class a <http://www.w3.org/2000/01/rdf-schema#Class> } UNION { ?class a <http://www.w3.org/2002/07/owl#Class> } UNION { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?anyParent } UNION { ?anySub <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?class } } FILTER(!isBlank(?class)) FILTER(!STRSTARTS(STR(?class), \"https://notebook.semantic.consulting/vocab#\")) OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?parentClass . FILTER(!STRSTARTS(STR(?parentClass), \"https://notebook.semantic.consulting/vocab#\")) } OPTIONAL { ?instance a ?class . FILTER(!isBlank(?instance)) OPTIONAL { ?instance <http://www.w3.org/2000/01/rdf-schema#label> ?instanceLabel } } OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#label> ?classLabel } } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#standing-on-shoulders-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#standing-on-shoulders> } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#standing-on-shoulders-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#nature-of-relationships",
      "@type": "sembook:Lab",
      "sembook:label": "The Nature of Relationships",
      "sembook:cssClass": "grid grid-cols-2 grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#nature-of-relationships-data",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Data",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col border-r border-slate-200",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n\n# ── Our data ── one fact. That is all we are going to say.\n\n<https://w3id.org/people/michael> ex:husbandOf ex:kate .\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#nature-of-relationships-semantics",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Semantics",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n\n# ── Our ontology ── what do these relationships MEAN?\n#\n# A husband is… what, more generally?\n# Does the relationship point back?\n# And what is the word for the other direction?\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#nature-of-relationships-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "col-span-2 overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#nature-of-relationships-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#nature-of-relationships> } }"
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#transitivity",
      "@type": "sembook:Lab",
      "sembook:label": "Transitivity",
      "sembook:cssClass": "grid grid-cols-2 grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#transitivity-data",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Data",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col border-r border-slate-200",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n@prefix schema: <http://schema.org/> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n\n# ── Our data ── one conference, one hotel, one performer.\n\n<https://uberconf.com> a schema:EducationalEvent ;\n    rdfs:label \"UberConf\" ;\n    schema:performer <https://w3id.org/people/michael> ;\n    schema:location ex:WestinWestminster .\n\nex:WestinWestminster a schema:Hotel ;\n    rdfs:label \"Westin Westminster\" ;\n    ex:locatedIn ex:Westminster .\n\nex:Westminster rdfs:label \"Westminster\" ;\n    ex:locatedIn ex:Colorado ;\n    ex:locatedIn ex:DenverMetro .\n\nex:Colorado rdfs:label \"Colorado\" .\nex:DenverMetro rdfs:label \"Denver\" .\n\n<https://w3id.org/people/michael> ex:locatedIn ex:WestinWestminster .\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#transitivity-semantics",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Semantics",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col",
          "sembook:initialContent": "@prefix ex: <https://example.com/ns#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n\n# ── Our ontology ──\n#\n# If I am in the hotel, and the hotel is in the city,\n# and the city is in the state… where am I?\n#\n# The graph does not know yet. Teach it what \"located in\" means.\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#transitivity-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "col-span-2 overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#transitivity-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#transitivity> } }"
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment",
      "@type": "sembook:Lab",
      "sembook:label": "Semantic Alignment",
      "sembook:cssClass": "grid grid-cols-2 grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-catalog",
          "@type": "sembook:JsonLdPanel",
          "sembook:label": "Catalog Record (Fetch it)",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col border-r border-slate-200",
          "sembook:initialContent": "{}",
          "sembook:fetchUrl": "../datasets/elizabeth-catalog-record.jsonld"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-semantics",
          "@type": "sembook:TurtleWriterPanel",
          "sembook:label": "Semantics",
          "sembook:cssClass": "col-span-1 overflow-hidden flex flex-col",
          "sembook:initialContent": "@prefix schema: <http://schema.org/> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n\n# ── Our ontology ──\n#\n# Two records. Two systems. No shared identifier.\n#\n# But an ISBN identifies exactly one book —\n# whoever holds it, however they spell the property.\n#\n# Say that. Precisely.\n"
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-tabs",
          "@type": "sembook:TabsPanel",
          "sembook:cssClass": "col-span-2 overflow-hidden flex flex-col",
          "sembook:panels": [
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-local-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Local Graph",
              "sembook:scope": { "@id": "sembook:LocalScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#semantic-alignment> } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-full-graph",
              "@type": "sembook:GraphPanel",
              "sembook:label": "Full Graph",
              "sembook:scope": { "@id": "sembook:CumulativeScope" },
              "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH ?g { ?s ?p ?o } VALUES ?g { <https://notebook.semantic.consulting/notebook1/#semantic-alignment> } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-entities",
              "@type": "sembook:EntityPanel",
              "sembook:label": "Entities",
              "sembook:scope": { "@id": "sembook:CumulativeScope" },
              "sembook:sparql": "SELECT DISTINCT ?class ?parentClass ?instance ?instanceLabel ?classLabel WHERE { GRAPH ?g { VALUES ?g { <https://notebook.semantic.consulting/notebook1/#semantic-alignment> } { { ?anyInstance a ?class } UNION { ?class a <http://www.w3.org/2000/01/rdf-schema#Class> } UNION { ?class a <http://www.w3.org/2002/07/owl#Class> } UNION { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?anyParent } UNION { ?anySub <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?class } } FILTER(!isBlank(?class)) FILTER(!STRSTARTS(STR(?class), \"https://notebook.semantic.consulting/vocab#\")) OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?parentClass . FILTER(!STRSTARTS(STR(?parentClass), \"https://notebook.semantic.consulting/vocab#\")) } OPTIONAL { ?instance a ?class . FILTER(!isBlank(?instance)) OPTIONAL { ?instance <http://www.w3.org/2000/01/rdf-schema#label> ?instanceLabel } } OPTIONAL { ?class <http://www.w3.org/2000/01/rdf-schema#label> ?classLabel } } }"
            },
            {
              "@id": "https://notebook.semantic.consulting/notebook1/#semantic-alignment-vocabulary",
              "@type": "sembook:VocabularyPanel",
              "sembook:label": "Vocabulary",
              "sembook:scope": { "@id": "sembook:CumulativeScope" }
            }
          ]
        }
      ]
    },
    {
      "@id": "https://notebook.semantic.consulting/notebook1/#querying-the-graph",
      "@type": "sembook:Lab",
      "sembook:label": "Querying the Graph",
      "sembook:cssClass": "grid grid-rows-[40vh_60vh] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#querying-the-graph-editor",
          "@type": "sembook:SparqlPanel",
          "sembook:label": "SPARQL",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:sampleQueries": [
            {
              "@type": "sembook:SampleQuery",
              "sembook:label": "All triples",
              "sembook:sparql": "SELECT ?s ?p ?o WHERE {\n  ?s ?p ?o\n}"
            },
            {
              "@type": "sembook:SampleQuery",
              "sembook:label": "Subjects and predicates in use",
              "sembook:sparql": "SELECT DISTINCT ?s ?p WHERE {\n  ?s ?p ?o\n}"
            },
            {
              "@type": "sembook:SampleQuery",
              "sembook:label": "Only Lab 1 (explicit GRAPH override)",
              "sembook:sparql": "SELECT ?s ?p ?o WHERE {\n  GRAPH <https://notebook.semantic.consulting/notebook1/#identity> { ?s ?p ?o }\n}"
            },
            {
              "@type": "sembook:SampleQuery",
              "sembook:label": "Reshape into one relation (CONSTRUCT)",
              "sembook:sparql": "CONSTRUCT {\n  ?s <http://example.org/vocab#relatedTo> ?o\n} WHERE {\n  ?s ?p ?o .\n  FILTER(!isLiteral(?o))\n}"
            }
          ]
        },
        {
          "@id": "https://notebook.semantic.consulting/notebook1/#querying-the-graph-result",
          "@type": "sembook:SparqlResultPanel",
          "sembook:label": "Result",
          "sembook:cssClass": "overflow-hidden flex flex-col"
        }
      ]
    }
  ]
}
