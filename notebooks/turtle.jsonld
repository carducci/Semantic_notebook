{
  "@context": {
    "sembook": "https://sembook.example.org/vocab#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "sembook:labs": { "@container": "@list" },
    "sembook:panels": { "@container": "@list" }
  },
  "@graph": [
    {
      "@id": "https://sembook.example.org/turtle",
      "@type": "sembook:Notebook",
      "sembook:title": "JSON-LD and Turtle",
      "sembook:labs": [
        { "@id": "https://sembook.example.org/turtle#side-by-side" }
      ]
    },
    {
      "@id": "https://sembook.example.org/turtle#side-by-side",
      "@type": "sembook:Lab",
      "sembook:label": "Two Syntaxes, One Graph",
      "sembook:cssClass": "grid grid-cols-2 grid-rows-[1fr] h-screen w-full",
      "sembook:init": {},
      "sembook:panels": [
        {
          "@id": "https://sembook.example.org/turtle#side-by-side-jsonld",
          "@type": "sembook:JsonLdPanel",
          "sembook:label": "JSON-LD",
          "sembook:cssClass": "overflow-hidden flex flex-col border-r border-slate-200",
          "sembook:initialContent": "{\n  \"@context\": {\n    \"@base\": \"http://example.org/\",\n    \"schema\": \"http://schema.org/\",\n    \"id\": \"@id\",\n    \"type\": \"@type\"\n  },\n  \"id\": \"/Person/1\",\n  \"type\": \"schema:Person\",\n  \"schema:name\": \"Ada Lovelace\",\n  \"schema:birthDate\": \"1815-12-10\"\n}"
        },
        {
          "@id": "https://sembook.example.org/turtle#side-by-side-turtle",
          "@type": "sembook:TurtlePanel",
          "sembook:label": "Turtle",
          "sembook:cssClass": "overflow-hidden flex flex-col",
          "sembook:sparql": "SELECT ?s ?p ?o WHERE { GRAPH <https://sembook.example.org/turtle#side-by-side> { ?s ?p ?o } }"
        }
      ]
    }
  ]
}
