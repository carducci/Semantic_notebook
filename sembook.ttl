@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix sembook: <https://notebook.semantic.consulting/vocab#> .

# ─────────────────────────────────────────────────────────────
# Ontology Declaration
# ─────────────────────────────────────────────────────────────

<https://notebook.semantic.consulting/vocab>
    a owl:Ontology ;
    rdfs:label "Semantic Notebook Vocabulary"@en ;
    rdfs:comment
        "Vocabulary for defining browser-based semantic teaching notebooks. A notebook is an ordered collection of labs, each occupying the full viewport. Each lab contains panels that are projections of a shared named graph. Designed for use as conference teaching tools and book companion material."@en ;
    dcterms:creator <https://mago.co/performers/michael-carducci> ;
    dcterms:description
        "The Semantic Notebook vocabulary provides terms for describing interactive RDF teaching environments. Notebooks are serialized as JSON-LD and interpreted by a browser-based runtime that manages a quad store, SPARQL query engine, and graph visualization layer."@en ;
    owl:versionIRI <https://notebook.semantic.consulting/vocab/0.2> ;
    owl:versionInfo "0.2"^^xsd:string .


# ─────────────────────────────────────────────────────────────
# Classes
# ─────────────────────────────────────────────────────────────

sembook:Notebook
    a owl:Class ;
    rdfs:label "Notebook"@en ;
    rdfs:comment
        "A named, ordered collection of Labs. Serialized as a JSON-LD file and fetched by the browser runtime on page load. The notebook is a first-class resource with its own IRI."@en .

sembook:Lab
    a owl:Class ;
    rdfs:label "Lab"@en ;
    rdfs:comment
        "The fundamental teaching unit. A lab occupies the full viewport and is identified by a fragment identifier on the notebook URL. Each lab owns exactly one named graph in the quad store. The lab IRI is the named graph IRI. Labs are rendered lazily via Intersection Observer and initialized eagerly at page load."@en .

sembook:Panel
    a owl:Class ;
    rdfs:label "Panel"@en ;
    rdfs:comment
        "An abstract base class for all panel types. A panel is a web component that is a projection of a lab's named graph. All panels share a common lifecycle: connectedCallback, initialize, render, update, disconnectedCallback. Panels query the quad store via a SPARQL query declared in their definition."@en .

sembook:JsonLdPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "JSON-LD Panel"@en ;
    rdfs:comment
        "An interactive JSON-LD editor panel. Provides a text editing surface, a fetch affordance for loading a resource by URI, and a Parse button that commits the editor contents to the lab's named graph via a graph:upsertFragment event. Editing does not update the graph — only the Parse button does. The panel's document is the source of truth for its fragment of the named graph."@en .

sembook:JsonLdContextPanel
    a owl:Class ;
    rdfs:subClassOf sembook:JsonLdPanel ;
    rdfs:label "JSON-LD Context Panel"@en ;
    rdfs:comment
        "A split-view JSON-LD editor: the document body and its @context are edited in two separate panes sharing one Parse button, making @context visible as data in its own right rather than metadata bolted onto the body. Same fetch affordance and Parse-commits-fragment behavior as JsonLdPanel."@en .

sembook:GraphPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "Graph Panel"@en ;
    rdfs:comment
        "A Cytoscape.js graph visualization panel. Renders the results of its SPARQL query as a node-edge diagram. Visually distinguishes asserted triples (solid), inferred triples (dashed), and externally fetched triples (dotted). The Cytoscape instance is created on first intersection and kept alive thereafter."@en .

sembook:EntityPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "Entity Panel"@en ;
    rdfs:comment
        "A list-based panel that displays named entities or vocabulary terms. Filtered by the panel's SPARQL query — typically either class instances (entities) or class/property definitions (vocabulary). Supports displaying both asserted and inferred type information."@en .

sembook:VocabularyPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "Vocabulary Panel"@en ;
    rdfs:comment
        "A vocabulary explorer distinct from EntityPanel: browses class and property definitions and their hierarchy (rdfs:subClassOf, rdfs:subPropertyOf) across the cumulative scope of a notebook's labs, rather than instance/class set membership. Visually distinguishes terms that are merely used or referenced (identity-only) from terms that carry their own describing assertions such as rdfs:label or rdfs:domain/range (described). Unlike other panel types it derives its own SPARQL scope internally rather than declaring sembook:sparql."@en .

sembook:TabsPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "Tabs Panel"@en ;
    rdfs:comment
        "A layout container panel that presents its child panels as switchable tabs. Owns the tab chrome and active-tab state. Child panels are standard Panel instances and have no knowledge of their tab context."@en .

sembook:TurtlePanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "Turtle Panel"@en ;
    rdfs:comment
        "A read-only Turtle serialization viewer. Renders the panel's SPARQL-selected scope of the quad store as syntax-highlighted Turtle. Extracts and displays the @context prefix mappings synced from JSON-LD panels as @prefix declarations, making the JSON-LD/Turtle correspondence visible — the same graph, two syntaxes."@en .

sembook:TurtleWriterPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "Turtle Writer Panel"@en ;
    rdfs:comment
        "An editable Turtle input panel, following the same Parse-button pattern as JsonLdPanel: editing the text does not update the lab's named graph until Parse commits it. Also extracts and syncs @prefix declarations into the lab's prefix map, mirroring JsonLdPanel's @context prefix sync."@en .

sembook:SparqlPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "SPARQL Panel"@en ;
    rdfs:comment
        "An interactive SPARQL query editor panel. Provides a query editing surface, a dropdown of author-defined sample queries (sembook:sampleQueries), and a Run button that executes the current query against the quad store — same Parse-button-family, explicit-commit interaction model as TurtleWriterPanel, but read-only: Run never mutates the lab's named graph. A query with no explicit GRAPH/FROM clause is implicitly scoped to the cumulative graph (asserted and inferred) spanning every lab up to and including this one; a query that explicitly scopes graphs overrides that default. Results are handed to a companion SparqlResultPanel via a sparql:executed event, not rendered by this panel directly."@en .

sembook:SparqlResultPanel
    a owl:Class ;
    rdfs:subClassOf sembook:Panel ;
    rdfs:label "SPARQL Result Panel"@en ;
    rdfs:comment
        "Renders the result of a companion SparqlPanel's most recently executed query, received via a sparql:executed event rather than a static sembook:sparql attribute. Offers three views — Table (always available), Turtle, and Graph — the latter two enabled only when the result is triple-shaped (a SELECT projecting exactly ?s ?p ?o, or a CONSTRUCT/DESCRIBE quad stream)."@en .

sembook:SampleQuery
    a owl:Class ;
    rdfs:label "Sample Query"@en ;
    rdfs:comment
        "A named, pre-authored SPARQL query offered in a SparqlPanel's sample-query dropdown — the same notebook-JSON-LD-declared UI slot other editor panels use for their Fetch-by-IRI affordance. Selecting one loads its sembook:sparql text into the editor; the learner still clicks Run to execute it."@en .

sembook:Scope
    a owl:Class ;
    rdfs:label "Scope"@en ;
    rdfs:comment
        "The graph scope a panel projects. A panel is always a projection of the quad store; its Scope says which named graphs are in view: exactly the owning lab's graph (LocalScope), or the cumulative union of every lab's graph up to and including the owning lab (CumulativeScope). In both cases each in-scope asserted graph brings its <graph-iri>-inferred companion along."@en .

sembook:LocalScope
    a sembook:Scope, owl:NamedIndividual ;
    rdfs:label "local scope"@en ;
    rdfs:comment
        "The panel projects only the owning lab's named graph (plus its inferred companion)."@en .

sembook:CumulativeScope
    a sembook:Scope, owl:NamedIndividual ;
    rdfs:label "cumulative scope"@en ;
    rdfs:comment
        "The panel projects the union of every lab's named graph from the first lab up to and including the owning lab (each with its inferred companion). This is how knowledge introduced in earlier labs stays visible in later ones."@en .


# ─────────────────────────────────────────────────────────────
# Notebook Properties
# ─────────────────────────────────────────────────────────────

sembook:title
    a owl:DatatypeProperty ;
    # Alignment, not reinvention: any dcterms-aware consumer reads sembook titles
    # for free — the same technique the #semantic-alignment lab teaches with
    # owl:equivalentProperty, applied to this vocabulary itself. subPropertyOf
    # rather than equivalentProperty because the entailment should be one-way:
    # every sembook:title is a dcterms:title, but not vice versa.
    rdfs:subPropertyOf dcterms:title ;
    rdfs:label "title"@en ;
    rdfs:comment "The display title of a Notebook."@en ;
    rdfs:domain sembook:Notebook ;
    rdfs:range xsd:string .

sembook:labs
    a owl:ObjectProperty ;
    rdfs:label "labs"@en ;
    rdfs:comment
        "Ordered list of Labs in a Notebook. Order determines scroll position and initialization sequence."@en ;
    rdfs:domain sembook:Notebook ;
    rdfs:range sembook:Lab .


# ─────────────────────────────────────────────────────────────
# Lab Properties
# ─────────────────────────────────────────────────────────────

sembook:label
    a owl:DatatypeProperty ;
    # See sembook:title for why this aligns via subPropertyOf instead of minting
    # an unaligned term: generic RDF tooling gets display labels for free.
    rdfs:subPropertyOf rdfs:label ;
    rdfs:label "label"@en ;
    rdfs:comment
        "A human-readable display label for a Lab, Panel, or SampleQuery. Used in the navigation strip for Labs, as the tab label for Panels within a TabsPanel, and as the option text for a SampleQuery in a SparqlPanel's dropdown."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( sembook:Lab sembook:Panel sembook:SampleQuery )
    ] ;
    rdfs:range xsd:string .

sembook:init
    a owl:ObjectProperty ;
    rdfs:label "init"@en ;
    rdfs:comment
        "Seed data for a Lab, expressed as an embedded JSON-LD graph. Loaded into the lab's named graph during the eager initialization phase at page load, before any Intersection Observer triggers. Provides the starting state of the graph before the user makes any edits."@en ;
    rdfs:domain sembook:Lab ;
    rdfs:range rdfs:Resource .

sembook:panels
    a owl:ObjectProperty ;
    rdfs:label "panels"@en ;
    rdfs:comment
        "Ordered list of Panels within a Lab or TabsPanel. Order determines rendering sequence and, for TabsPanel, tab order."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( sembook:Lab sembook:TabsPanel )
    ] ;
    rdfs:range sembook:Panel .

sembook:cssClass
    a owl:DatatypeProperty ;
    rdfs:label "CSS class"@en ;
    rdfs:comment
        "Tailwind CSS utility classes to apply to the rendered component element. Controls layout, sizing, overflow, and spacing. Applied directly as the HTML class attribute — no mapping or interpretation. Different labs and panels carry different class strings to achieve different layouts without any framework assumptions."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( sembook:Lab sembook:Panel )
    ] ;
    rdfs:range xsd:string .


# ─────────────────────────────────────────────────────────────
# Panel Properties
# ─────────────────────────────────────────────────────────────

sembook:sparql
    a owl:DatatypeProperty ;
    rdfs:label "SPARQL query"@en ;
    rdfs:comment
        "A SPARQL query string. On a Panel, this is a SELECT query that determines what data the panel renders each time it re-renders — local graph, full graph, entity list, vocabulary list. On a SampleQuery, this is the query text (any form — SELECT, CONSTRUCT, ASK) offered as a starting point in a SparqlPanel's dropdown, loaded into the editor verbatim rather than executed automatically."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( sembook:Panel sembook:SampleQuery )
    ] ;
    rdfs:range xsd:string .

sembook:scope
    a owl:ObjectProperty ;
    rdfs:label "scope"@en ;
    rdfs:comment
        "The graph scope this panel projects — sembook:LocalScope or sembook:CumulativeScope. Declared in the notebook definition so that scope is data, never inferred from a display label. When absent, the runtime default is panel-type-specific: GraphPanel defaults to local scope; EntityPanel and VocabularyPanel default to cumulative scope (an entity or term introduced two labs ago is still known)."@en ;
    rdfs:domain sembook:Panel ;
    rdfs:range sembook:Scope .

sembook:sampleQueries
    a owl:ObjectProperty ;
    rdfs:label "sample queries"@en ;
    rdfs:comment
        "Ordered list of SampleQuery entries offered in a SparqlPanel's dropdown, filling the same notebook-JSON-LD-declared UI slot other editor panels use for their Fetch-by-IRI affordance."@en ;
    rdfs:domain sembook:SparqlPanel ;
    rdfs:range sembook:SampleQuery .

sembook:initialContent
    a owl:DatatypeProperty ;
    rdfs:label "initial content"@en ;
    rdfs:comment
        "Seed text loaded into a panel's primary editing surface before the user makes any edits — the JSON-LD document body for JsonLdPanel and JsonLdContextPanel, or the Turtle text for TurtleWriterPanel. Distinct from sembook:init, which seeds the lab's named graph directly rather than an editor surface; this property only populates what the user sees until they hit Parse."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( sembook:JsonLdPanel sembook:TurtleWriterPanel )
    ] ;
    rdfs:range xsd:string .

sembook:initialContext
    a owl:DatatypeProperty ;
    rdfs:label "initial context"@en ;
    rdfs:comment
        "Seed text loaded into a JsonLdContextPanel's separate @context editing pane before the user makes any edits, alongside sembook:initialContent for the document body."@en ;
    rdfs:domain sembook:JsonLdContextPanel ;
    rdfs:range xsd:string .

sembook:fetchUrl
    a owl:DatatypeProperty ;
    rdfs:label "fetch URL"@en ;
    rdfs:comment
        "Pre-fills a panel's Fetch-by-IRI input with this URL before the user touches it. Only the input is seeded — fetching remains a deliberate click, and parsing the fetched document another, preserving the explicit-commit interaction model (ADR-019). Useful when a lab's choreography depends on fetching a specific curated resource and typing the URL live would be friction, not teaching."@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( sembook:JsonLdPanel sembook:TurtleWriterPanel )
    ] ;
    rdfs:range xsd:string .


# ─────────────────────────────────────────────────────────────
# Named Graph Convention (informative)
# ─────────────────────────────────────────────────────────────
#
# The following naming convention is not enforced by this ontology
# but is required by the runtime:
#
#   Lab named graph:          <lab-iri>
#   Lab inferred graph:       <lab-iri-inferred>
#   Panel fragment identity:  <panel-iri>   (used as graph key in upsertFragment)
#
# The default graph contains the notebook and lab definitions
# as loaded from the JSON-LD file at bootstrap time.
#
# ─────────────────────────────────────────────────────────────
